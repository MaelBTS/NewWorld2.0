{% extends 'base.html.twig' %}

{% block title %}Devenir Producteur - NewWorld{% endblock %}

{% block body %}
{# Import des polices et icônes pour le design #}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --primary: #10b981;
        --primary-dark: #059669;
        --bg-gray: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --error: #ef4444;
    }

    body {
        background-color: var(--bg-gray);
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--text-main);
        margin: 0;
    }

    .register-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 60px 20px;
    }

    .register-card {
        background: white;
        width: 100%;
        max-width: 800px;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.04);
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }

    /* En-tête */
    .card-header {
        background: linear-gradient(to bottom, #ffffff, #f8fafc);
        padding: 40px 40px 30px 40px;
        text-align: center;
        border-bottom: 1px solid #e2e8f0;
    }

    .logo-icon {
        background: #ecfdf5;
        color: var(--primary);
        width: 65px;
        height: 65px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 1.8rem;
    }

    .card-header h1 { font-weight: 800; font-size: 2rem; margin-bottom: 10px; color: var(--text-main); }
    .card-header p { color: var(--text-muted); font-size: 1rem; margin: 0; }

    /* Formulaire */
    .card-body { padding: 40px; }

    .form-section-title {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--primary);
        margin: 0 0 25px 0;
    }

    .form-section-title::after { content: ""; flex: 1; height: 1px; background: #e2e8f0; }

    .grid-form {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 35px;
    }

    .full-width { grid-column: 1 / -1; }

    .form-group label {
        display: block;
        font-weight: 700;
        font-size: 0.85rem;
        margin-bottom: 8px;
        color: var(--text-main);
    }

    .form-control {
        width: 100%;
        padding: 14px 16px;
        background: #f8fafc;
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        font-size: 0.95rem;
        transition: all 0.2s;
        font-family: inherit;
    }

    .form-control:focus {
        background: white;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15);
        outline: none;
    }

    .form-error {
        color: var(--error);
        font-size: 0.8rem;
        font-weight: 600;
        margin-top: 5px;
        display: block;
    }

    /* Bouton */
    .btn-submit {
        background: var(--primary);
        color: white;
        border: none;
        width: 100%;
        padding: 18px;
        border-radius: 14px;
        font-weight: 800;
        font-size: 1.05rem;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

    .btn-submit:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.3); }

    .card-footer {
        background: #f8fafc;
        padding: 25px;
        text-align: center;
        border-top: 1px solid #e2e8f0;
        font-weight: 500;
    }

    .card-footer a { color: var(--primary); font-weight: 700; text-decoration: none; }

    /* Alertes globales */
    .alert-box {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #b91c1c;
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 30px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    @media (max-width: 640px) {
        .grid-form { grid-template-columns: 1fr; gap: 15px; }
        .card-body { padding: 25px; }
        .card-header { padding: 30px 20px; }
    }
</style>

<div class="register-wrapper">
    <div class="register-card">
        
        <div class="card-header">
            <div class="logo-icon"><i class="fa-solid fa-wheat-awn"></i></div>
            <h1>Compte Producteur</h1>
        </div>

        <div class="card-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            {# Affichage des erreurs globales #}
            {% if not form.vars.valid %}
                <div class="alert-box">
                    <i class="fa-solid fa-triangle-exclamation fa-lg"></i>
                    Veuillez corriger les erreurs indiquées ci-dessous.
                </div>
            {% endif %}

            <div class="form-section-title"><i class="fa-solid fa-building"></i> Informations générales</div>
            <div class="grid-form">
                <div class="form-group">
                    {{ form_label(form.nom) }}
                    {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Ex: La Ferme du Moulin'}}) }}
                    <div class="form-error">{{ form_errors(form.nom) }}</div>
                </div>
                <div class="form-group">
                    {{ form_label(form.numeroSiret) }}
                    {{ form_widget(form.numeroSiret, {'attr': {'class': 'form-control', 'placeholder': '14 chiffres'}}) }}
                    <div class="form-error">{{ form_errors(form.numeroSiret) }}</div>
                </div>
            </div>

            <div class="form-section-title"><i class="fa-solid fa-address-book"></i> Coordonnées</div>
            <div class="grid-form">
                <div class="form-group">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'contact@domaine.fr'}}) }}
                    <div class="form-error">{{ form_errors(form.email) }}</div>
                </div>
                <div class="form-group">
                    {{ form_label(form.telephone) }}
                    {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'placeholder': '06 12 34 56 78'}}) }}
                    <div class="form-error">{{ form_errors(form.telephone) }}</div>
                </div>
            </div>

            <div class="form-section-title"><i class="fa-solid fa-location-dot"></i> Adresse</div>
            <div class="grid-form">
                <div class="form-group full-width">
                    {{ form_label(form.adresse) }}
                    {{ form_widget(form.adresse, {'attr': {'class': 'form-control', 'placeholder': 'Numéro et nom de rue, lieu-dit...'}}) }}
                    <div class="form-error">{{ form_errors(form.adresse) }}</div>
                </div>
                <div class="form-group">
                    {{ form_label(form.codePostal) }}
                    {{ form_widget(form.codePostal, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 05000'}}) }}
                    <div class="form-error">{{ form_errors(form.codePostal) }}</div>
                </div>
                <div class="form-group">
                    {{ form_label(form.ville) }}
                    {{ form_widget(form.ville, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Gap'}}) }}
                    <div class="form-error">{{ form_errors(form.ville) }}</div>
                </div>
            </div>

            <div class="form-section-title"><i class="fa-solid fa-lock"></i> Sécurité</div>
            <div class="grid-form">
                {% if form.plainPassword is defined %}
                    <div class="form-group full-width">
                        {{ form_label(form.plainPassword, 'Mot de passe') }}
                        {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Votre mot de passe'}}) }}
                        <div class="form-error">{{ form_errors(form.plainPassword) }}</div>
                    </div>
                {% endif %}
            </div>

            {# 
               MÉCANIQUE ANTIBUG :
               Si tu ajoutes "statut", "dateCreation" ou n'importe quel autre champ dans ton ProducteurType.php, 
               cette boucle va les trouver et les afficher proprement ici sans que tu aies besoin de modifier ce fichier Twig !
            #}
            {% set known_fields = ['nom', 'numeroSiret', 'email', 'telephone', 'adresse', 'codePostal', 'ville', 'plainPassword', '_token'] %}
            
            {% for child in form %}
                {% if child.vars.name not in known_fields %}
                    <div class="form-group" style="margin-bottom: 20px;">
                        {{ form_label(child) }}
                        {{ form_widget(child, {'attr': {'class': 'form-control'}}) }}
                        <div class="form-error">{{ form_errors(child) }}</div>
                    </div>
                {% endif %}
            {% endfor %}

            {# On affiche les tokens de sécurité cachés obligatoires #}
            {{ form_rest(form) }}

            <button type="submit" class="btn-submit">
                Créer mon compte Producteur <i class="fa-solid fa-arrow-right"></i>
            </button>

            {{ form_end(form) }}
        </div>

        <div class="card-footer">
            Déjà partenaire ? <a href="/">Me connecter</a>
        </div>
    </div>
</div>
{% endblock %}