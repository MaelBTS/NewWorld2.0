{% extends 'base.html.twig' %}

{% block title %}ADMIN | GESTION{% endblock %}

{% block body %}
{# Import de la police Inter (standard du design moderne) #}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    /* CHARTE GRAPHIQUE RADICALE */
    :root {
        --green: #10b981;
        --black: #000000;
        --white: #ffffff;
        --gray-light: #f5f5f5;
        --border: #e5e7eb;
    }

    body { 
        background-color: var(--white); 
        font-family: 'Inter', sans-serif; 
        color: var(--black); 
        margin: 0;
        padding: 0;
    }

    /* ESPACEMENT HAUT */
    .app-container {
        padding-top: 80px;
        max-width: 1100px;
        margin: 0 auto;
    }

    /* HEADER */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid var(--black);
        padding-bottom: 30px;
        margin-bottom: 50px;
    }

    h1 {
        font-weight: 900;
        font-size: 2.5rem;
        letter-spacing: -2px;
        margin: 0;
        text-transform: uppercase;
    }

    /* BOUTONS CARRES */
    .btn-action {
        background: var(--green);
        color: white;
        padding: 15px 30px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        border: none;
        text-decoration: none;
        letter-spacing: 1px;
        transition: 0.2s;
        display: inline-block;
    }

    .btn-action:hover {
        background: var(--black);
        color: white;
    }

    /* ONGLETS (TABS) */
    .tabs-nav {
        display: flex;
        gap: 40px;
        margin-bottom: 30px;
        list-style: none;
        padding: 0;
    }

    .tab-link {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        color: #999;
        text-decoration: none;
        padding-bottom: 10px;
        border-bottom: 3px solid transparent;
        transition: 0.3s;
    }

    .tab-link.active {
        color: var(--black);
        border-bottom: 3px solid var(--green);
    }

    /* TABLEAU MINIMALISTE */
    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    th {
        text-align: left;
        padding: 20px;
        background: var(--black);
        color: white;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    td {
        padding: 25px 20px;
        border-bottom: 1px solid var(--border);
        font-size: 0.9rem;
    }

    tr:hover {
        background-color: var(--gray-light);
    }

    .row-title {
        font-weight: 700;
        text-transform: uppercase;
    }

    /* ACTIONS DANS LA TABLE */
    .link-edit {
        color: var(--black);
        text-decoration: none;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.7rem;
        border-bottom: 2px solid var(--green);
    }

    .btn-resilier {
        background: none;
        border: 2px solid var(--black);
        color: var(--black);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.65rem;
        padding: 5px 12px;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn-resilier:hover {
        background: var(--black);
        color: var(--white);
    }

    .btn-delete {
        color: #ff0000;
        background: none;
        border: none;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.7rem;
        cursor: pointer;
    }

    /* STATUTS */
    .status-active { color: var(--green); font-weight: 800; font-size: 0.7rem; text-transform: uppercase; }
    .status-pending { color: #b45309; font-weight: 800; font-size: 0.7rem; text-transform: uppercase; }

    /* MODALE */
    .custom-modal {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(255, 255, 255, 0.98);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-box {
        width: 100%;
        max-width: 600px;
        padding: 50px;
        border: 2px solid var(--black);
    }

    .form-group label {
        display: block;
        text-transform: uppercase;
        font-weight: 700;
        font-size: 0.7rem;
        margin-bottom: 10px;
    }

    .form-group input, .form-group select, .form-group textarea {
        width: 100%;
        padding: 15px;
        border: 1px solid var(--black);
        margin-bottom: 20px;
        font-family: 'Inter';
    }

    .alert-success {
        background: var(--green);
        color: white;
        padding: 20px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 30px;
        font-size: 0.8rem;
    }
</style>

<div class="app-container">
    
    {# NOTIFICATIONS #}
    {% for message in app.flashes('success') %}
        <div class="alert-success">{{ message }}</div>
    {% endfor %}

    <div class="header">
        <h1>Management</h1>
        <div class="d-flex gap-2">
            <a href="{{ path('app_admin_dashboard', {type: 'prod', new: 1}) }}" class="btn-action">Ajouter Producteur</a>
            <a href="{{ path('app_admin_dashboard', {type: 'sec', new: 1}) }}" class="btn-action">Ajouter Secretaire</a>
        </div>
    </div>

    {# TABS #}
    <div class="tabs-nav">
        <a href="{{ path('app_admin_dashboard', {tab: 'prod'}) }}" class="tab-link {{ activeTab == 'prod' ? 'active' : '' }}">Producteurs</a>
        <a href="{{ path('app_admin_dashboard', {tab: 'sec'}) }}" class="tab-link {{ activeTab == 'sec' ? 'active' : '' }}">Secretaires</a>
        <a href="{{ path('app_admin_dashboard', {tab: 'demandes'}) }}" class="tab-link {{ activeTab == 'demandes' ? 'active' : '' }}">Demandes</a>
        <a href="{{ path('app_admin_dashboard', {tab: 'audits'}) }}" class="tab-link {{ activeTab == 'audits' ? 'active' : '' }}">Audits</a>
    </div>

    {# TABLES #}
    {% if activeTab == 'prod' %}
        <table>
            <thead>
                <tr>
                    <th>Identité / Contrat</th>
                    <th>Siret</th>
                    <th>Statut Contractuel</th>
                    <th style="text-align: right;">Gestion</th>
                </tr>
            </thead>
            <tbody>
                {% for p in producteurs %}
                <tr>
                    <td class="row-title">
                        {{ p.nom }}<br>
                        <small style="text-transform: none; color: #999; font-weight: 400;">Depuis le {{ p.dateCreation|date('d/m/Y') }}</small>
                    </td>
                    <td><code>{{ p.numeroSiret }}</code></td>
                    <td>
                        {# Affichage du statut avec la nouvelle logique Admin [cite: 6] #}
                        {% if p.deleteAt %}
                            <span class="status-pending">Fin : {{ p.deleteAt|date('d/m/Y') }}</span>
                        {% else %}
                            <span class="{% if p.statut == 'Actif' %} status-active {% else %} status-pending {% endif %}">{% if p.statut == 'Actif' %} Partenaire Actif {% else %} En audit {% endif %}</span>
                        {% endif %}
                    </td>
                    <td style="text-align: right;">
                        <div style="display: flex; justify-content: flex-end; align-items: center; gap: 20px;">
                            
                            {# Bouton Résilier spécifique Admin [cite: 6] #}
                            {% if not p.deleteAt %}
                            <form method="post" action="{{ path('app_admin_resilier_producteur', {id: p.id}) }}" onsubmit="return confirm('ADMIN : Confirmer la résiliation contractuelle (Préavis 6 mois) ?');">
                                <button type="submit" class="btn-resilier">Résilier</button>
                            </form>
                            {% endif %}

                            <a href="{{ path('app_admin_dashboard', {type: 'prod', edit: p.id, tab: 'prod'}) }}" class="link-edit">Editer</a>
                            
                            <form method="post" action="{{ path('app_admin_delete', {type: 'prod', id: p.id}) }}" onsubmit="return confirm('Supprimer définitivement ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ p.id) }}">
                                <button type="submit" class="btn-delete">X</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% elseif activeTab == 'sec' %}
        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Email</th>
                    <th style="text-align: right;">Gestion</th>
                </tr>
            </thead>
            <tbody>
                {% for s in secretaires %}
                <tr>
                    <td class="row-title">{{ s.nom }}</td>
                    <td>{{ s.email }}</td>
                    <td style="text-align: right;">
                        <div style="display: flex; justify-content: flex-end; align-items: center; gap: 20px;">
                            <a href="{{ path('app_admin_dashboard', {type: 'sec', edit: s.id, tab: 'sec'}) }}" class="link-edit">Editer</a>
                            <form method="post" action="{{ path('app_admin_delete', {type: 'sec', id: s.id}) }}" onsubmit="return confirm('Supprimer ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ s.id) }}">
                                <button type="submit" class="btn-delete">X</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% elseif activeTab == 'demandes' %}
        <table>
            <thead>
                <tr>
                    <th>Identité</th>
                    <th>Siret</th>
                    <th>Ville</th>
                    <th>Date de la demande</th>
                    <th>Commentaire</th>
                    <th style="text-align: right;">Gestion</th>
                </tr>
            </thead>
            <tbody>
                {% for d in demandes %}
                <tr>
                    <td class="row-title">{{ d.nom }}</td>
                    <td><code>{{ d.numeroSiret }}</code></td>
                    <td>{{ d.ville|upper }}</td>
                    <td>{{ d.dateDemande|date() }}</td>
                    <td>{{ d.commentaire }}</td>
                    <td style="text-align: right;">
                        <form method="post" action="{{ path('app_admin_valider_demande', {id: d.id}) }}" style="display:inline;" onsubmit="return confirm('Valider cette demande et créer le producteur + audit ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('valider_demande' ~ d.id) }}">
                            <button type="submit" class="link-edit" style="border:none;background:none;cursor:pointer;">Valider</button>
                        </form>
                        <form method="post" action="{{ path('app_admin_delete', {type: 'demandes', id: d.id}) }}" style="display: inline;" onsubmit="return confirm('Refuser ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ d.id) }}">
                            <button type="submit" class="btn-delete">X</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% elseif activeTab == 'audits' %}
        <table>
            <thead>
                <tr>
                    <th>Producteur</th>
                    <th>Date audit</th>
                    <th>Résultat</th>
                    <th>Commentaire</th>
                    <th style="text-align: right;">Gestion</th>
                </tr>
            </thead>
            <tbody>
                {% for a in audits %}
                <tr>
                    <td class="row-title">
                        {{ a.producteur.nom }}
                    </td>
                    <td>{{ a.dateAudit|date('d/m/Y') }}</td>
                    <td>{{ a.resultat }}</td>
                    <td>{{ a.commentaire }}</td>
                    <td style="text-align: right;">
                        {# Bouton: valider audit = producteur devient Actif, audit supprimé #}
                        <form method="post"
                            action="{{ path('app_admin_valider_audit', {id: a.id}) }}"
                            style="display:inline;"
                            onsubmit="return confirm('Valider cet audit et activer le producteur ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('valider_audit' ~ a.id) }}">
                            <button type="submit" class="link-edit" style="border:none;background:none;cursor:pointer;">
                                Valider audit
                            </button>
                        </form>

                        {# Suppression brute de l’audit si besoin #}
                        <form method="post"
                            action="{{ path('app_admin_delete', {type: 'audits', id: a.id}) }}"
                            style="display:inline;"
                            onsubmit="return confirm('Supprimer cet audit ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ a.id) }}">
                            <button type="submit" class="btn-delete">X</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>

{# MODALE MINIMALISTE #}
{% if form %}
<div class="custom-modal">
    <div class="modal-box">
        <h2 style="font-weight: 900; text-transform: uppercase; margin-bottom: 30px;">
            {{ isNew ? 'Nouveau' : 'Editer' }} {{ type }}
        </h2>
        
        {{ form_start(form) }}
            <div class="form-group">
                {{ form_rest(form) }}
            </div>
            
            <div style="margin-top: 40px; display: flex; justify-content: space-between; align-items: center;">
                <a href="{{ path('app_admin_dashboard', {tab: type}) }}" style="color: black; font-weight: 700; text-transform: uppercase; font-size: 0.7rem; text-decoration: none;">Annuler</a>
                <button type="submit" class="btn-action">Sauvegarder</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endif %}

{% endblock %}