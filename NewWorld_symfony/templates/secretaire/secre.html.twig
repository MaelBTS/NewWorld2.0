{% extends 'base.html.twig' %}

{% block title %}Espace Secrétariat{% endblock %}

{% block body %}
<style>
    body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        background: #f9fafb;
    }

    .page {
        padding: 60px 8%;
    }

    h1 {
        font-size: 2.2rem;
        font-weight: 800;
        margin-bottom: 10px;
        color: #111827;
    }

    .subtitle {
        color: #6b7280;
        margin-bottom: 40px;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .btn-main {
        background: #111827;
        color: white;
        padding: 12px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.2s;
    }

    .btn-main:hover {
        background: #065f46;
        color: white;
    }

    .card {
        background: white;
        border-radius: 12px;
        border: 1px solid #f0f0f0;
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: #f3f4f6;
    }

    th {
        text-align: left;
        font-size: 0.75rem;
        text-transform: uppercase;
        color: #6b7280;
        padding: 16px;
    }

    td {
        padding: 18px 16px;
        border-top: 1px solid #f3f4f6;
        font-size: 0.9rem;
    }

    .name {
        font-weight: 600;
        color: #111827;
    }

    .sub {
        font-size: 0.8rem;
        color: #6b7280;
    }

    .badge {
        background: #ecfdf5;
        color: #065f46;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .btn-edit {
        background: #f3f4f6;
        padding: 8px 12px;
        border-radius: 6px;
        text-decoration: none;
        color: #111827;
        font-size: 0.8rem;
    }

    .btn-edit:hover {
        background: #e5e7eb;
        color: #065f46;
    }

    .empty {
        text-align: center;
        padding: 50px;
        color: #9ca3af;
    }

    /* MODAL CLEAN */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .modal {
        background: white;
        border-radius: 12px;
        width: 100%;
        max-width: 600px;
        padding: 30px;
    }

    .modal h2 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-control {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
    }

    .form-control:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
        outline: none;
    }

    .actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-secondary {
        border: 1px solid #e5e7eb;
        padding: 10px 15px;
        border-radius: 6px;
        text-decoration: none;
        color: #374151;
    }

    .btn-primary {
        background: #111827;
        color: white;
        padding: 10px 18px;
        border-radius: 6px;
        border: none;
    }

    .btn-primary:hover {
        background: #065f46;
    }

</style>

<div class="page">

    <div class="top-bar">
        <div>
            <h1>Espace secretaire</h1>
            <div class="subtitle">Gestion des exploitations</div>
        </div>

        <a href="{{ path('app_secretaire_dashboard', {new: 1}) }}" class="btn-main">
            + Nouveau
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success mb-4">
            {{ message }}
        </div>
    {% endfor %}

    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>Producteur</th>
                    <th>SIRET</th>
                    <th>Ville</th>
                    <th>Statut</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                {% for p in producteurs %}
                    <tr>
                        <td>
                            <div class="name">{{ p.nom }}</div>
                            <div class="sub">{{ p.email }}</div>
                        </td>

                        <td>{{ p.numeroSiret }}</td>
                        <td>{{ p.ville }}</td>

                        <td>
                            <span class="badge">{{ p.statut|upper }}</span>
                        </td>

                        <td>
                            <a href="{{ path('app_secretaire_dashboard', {edit: p.id}) }}" class="btn-edit">
                                Modifier
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="empty">
                            Aucun producteur
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div>

{% if form %}
<div class="modal-overlay">
    <div class="modal">

        <h2>{{ editId ? 'Modifier le producteur' : 'Nouveau producteur' }}</h2>

        {{ form_start(form) }}

            <div class="form-group">
                {{ form_row(form.nom) }}
            </div>

            <div class="form-group">
                {{ form_row(form.email) }}
            </div>

            {{ form_rest(form) }}

            <div class="actions">
                <a href="{{ path('app_secretaire_dashboard') }}" class="btn-secondary">Annuler</a>
                <button class="btn-primary">
                    {{ editId ? 'Enregistrer' : 'Créer' }}
                </button>
            </div>

        {{ form_end(form) }}

    </div>
</div>
{% endif %}

{% endblock %}